{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ch-testimonials-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<section class="ch-testimonials ch-testimonials-{{ section.id }}" data-ch-testimonials>
  <div class="ch-testimonials__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ch-testimonials__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ch-testimonials__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="ch-testimonials__track-wrapper">
      <div class="ch-testimonials__track">
        {%- for block in section.blocks -%}
          <div class="ch-testimonials__card" {{ block.shopify_attributes }}>
            <div class="ch-testimonials__stars">
              {%- assign rating = block.settings.rating | times: 1 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}★{%- else -%}☆{%- endif -%}
              {%- endfor -%}
            </div>
            <p class="ch-testimonials__text">"{{ block.settings.review_text }}"</p>
            <div class="ch-testimonials__author">
              <div class="ch-testimonials__avatar">
                {%- if block.settings.avatar != blank -%}
                  <img src="{{ block.settings.avatar | image_url: width: 88 }}" alt="{{ block.settings.customer_name }}" width="44" height="44" loading="lazy">
                {%- else -%}
                  {{ block.settings.customer_name | slice: 0 | upcase }}
                {%- endif -%}
              </div>
              <div class="ch-testimonials__author-info">
                <strong>{{ block.settings.customer_name }}</strong>
                <span>{{ block.settings.customer_location }}</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="ch-testimonials__nav">
      <button class="ch-testimonials__btn ch-testimonials__btn--prev" type="button" aria-label="Previous testimonial">&#8592;</button>
      <div class="ch-testimonials__dots"></div>
      <button class="ch-testimonials__btn ch-testimonials__btn--next" type="button" aria-label="Next testimonial">&#8594;</button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Testimonials",
  "tag": "section",
  "class": "ch-testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Real results from real people"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8FAF9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Priya S."
        },
        {
          "type": "text",
          "id": "customer_location",
          "label": "Customer Location",
          "default": "Mumbai"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Customer Photo (optional)"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "CueHealth supplements have completely transformed my energy levels. I feel more focused and active throughout the day. Highly recommended!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Testimonials",
