{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

<!-- Contact Hero -->
<div class="ch-page-hero">
  <div class="ch-page-hero__inner">
    <p class="ch-page-hero__eyebrow">We're here to help</p>
    <h1 class="ch-page-hero__heading">Contact Us</h1>
    <p class="ch-page-hero__sub">Reach out via WhatsApp, email, or the form below. We respond within 24 hours.</p>
  </div>
</div>

<div class="ch-contact-wrapper page-width">
  <!-- Contact Details -->
  <div class="ch-contact-details">
    <h2>Get in Touch</h2>

    <div class="ch-contact-card">
      <div class="ch-contact-card__icon">📧</div>
      <div>
        <strong>Email Us</strong>
        <a href="mailto:hello@cuehealth.in">hello@cuehealth.in</a>
        <span>We reply within 24 hours</span>
      </div>
    </div>

    <div class="ch-contact-card ch-contact-card--whatsapp">
      <div class="ch-contact-card__icon">💬</div>
      <div>
        <strong>WhatsApp</strong>
        <a href="https://wa.me/917455918832?text=Hi%21+I+have+a+query+about+CueHealth+products." target="_blank" rel="noopener">
          +91 7455918832
        </a>
        <span>Mon – Sat, 10am – 7pm IST</span>
      </div>
    </div>

    <div class="ch-contact-card">
      <div class="ch-contact-card__icon">📍</div>
      <div>
        <strong>Our Office</strong>
        <span>Upper Ground Floor, 003,</span>
        <span>Kh No 485/Marwah Homes, Sector 73,</span>
        <span>Sarfabad, Noida, UP – 201301</span>
      </div>
    </div>

    <div class="ch-contact-card">
      <div class="ch-contact-card__icon">🕐</div>
      <div>
        <strong>Business Hours</strong>
        <span>Monday – Saturday</span>
        <span>10:00 AM – 7:00 PM IST</span>
      </div>
    </div>

    <a
      href="https://wa.me/917455918832?text=Hi%21+I+have+a+query+about+CueHealth+products."
      target="_blank"
      rel="noopener"
      class="ch-whatsapp-cta-btn"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Chat with us on WhatsApp
    </a>
  </div>

  <!-- Contact Form -->
  <div class="ch-contact-form">
    <h2>Send a Message</h2>
    {%- form 'contact', id: 'CueHealthContactForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="ch-form-success">
          <span>✅</span>
          <div>
            <strong>Thank you for reaching out!</strong>
            <p>We'll get back to you within 24 hours at your provided email.</p>
          </div>
        </div>
      {%- endif -%}
      {%- if form.errors -%}
        <div class="ch-form-error">
          Please correct the errors below and try again.
        </div>
      {%- endif -%}

      <div class="ch-form-row">
        <div class="ch-form-group">
          <label for="contact-name">Your Name *</label>
          <input
            type="text"
            id="contact-name"
            name="contact[name]"
            autocomplete="name"
            required
            placeholder="Priya Sharma"
            value="{% if form.name %}{{ form.name }}{% endif %}"
          >
        </div>
        <div class="ch-form-group">
          <label for="contact-email">Email Address *</label>
          <input
            type="email"
            id="contact-email"
            name="contact[email]"
            autocomplete="email"
            required
            autocorrect="off"
            autocapitalize="off"
            placeholder="priya@example.com"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            {%- if form.errors contains 'email' %} aria-invalid="true"{% endif %}
          >
        </div>
      </div>

      <div class="ch-form-group">
        <label for="contact-phone">Phone / WhatsApp (optional)</label>
        <input
          type="tel"
          id="contact-phone"
          name="contact[phone]"
          autocomplete="tel"
          placeholder="+91 98765 43210"
        >
      </div>

      <div class="ch-form-group">
        <label for="contact-subject">Subject *</label>
        <select id="contact-subject" name="contact[subject]" required>
          <option value="">Select a topic…</option>
          <option value="Order Enquiry">Order Enquiry</option>
          <option value="Product Question">Product Question</option>
          <option value="Return / Refund">Return / Refund</option>
          <option value="Bulk / Wholesale">Bulk / Wholesale</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="ch-form-group">
        <label for="contact-message">Message *</label>
        <textarea
          id="contact-message"
          name="contact[body]"
          rows="5"
          required
          placeholder="Tell us how we can help you…"
        >{% if form.body %}{{ form.body }}{% endif %}</textarea>
      </div>

      <button type="submit" class="ch-form-submit">Send Message</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact CueHealth",
  "tag": "section",
  "class": "ch-contact-section",
  "settings": [],
  "presets": [
    { "name": "Contact CueHealth" }
  ]
}
{% endschema %}
