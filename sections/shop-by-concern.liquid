{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ch-concerns-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="ch-concerns ch-concerns-{{ section.id }}">
  <div class="ch-concerns__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ch-concerns__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ch-concerns__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="ch-concerns__grid">
      {%- for block in section.blocks -%}
        <a
          class="ch-concern-item"
          href="{{ block.settings.link | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          <div class="ch-concern-item__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 220 }}"
                alt="{{ block.settings.label }}"
                width="110"
                height="110"
                loading="lazy"
              >
            {%- else -%}
              {{ block.settings.emoji }}
            {%- endif -%}
          </div>
          <span class="ch-concern-item__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Concern",
  "tag": "section",
  "class": "ch-concerns-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Concern"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Find the right supplement for your wellness goal"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Category Label",
          "default": "Immunity"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (if no image)",
          "default": "🛡️"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Concern",
      "blocks": [
        {
          "type": "concern",
          "settings": { "label": "Sleep & Recovery", "emoji": "😴" }
        },
        {
          "type": "concern",
          "settings": { "label": "Immunity", "emoji": "🛡️" }
        },
        {
          "type": "concern",
          "settings": { "label": "Women's Health", "emoji": "💜" }
        },
        {
          "type": "concern",
          "settings": { "label": "Gut Health", "emoji": "🌱" }
        },
        {
          "type": "concern",
          "settings": { "label": "Energy & Focus", "emoji": "⚡" }
        }
      ]
    }
  ]
}
{% endschema %}
