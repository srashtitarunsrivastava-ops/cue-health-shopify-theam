{{ 'custom-cuehealth.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ch-hero-{{ section.id }} {
    min-height: {{ section.settings.min_height_mobile }}vh;
    background-color: {{ section.settings.fallback_bg_color }};
  }
  @media screen and (min-width: 750px) {
    .ch-hero-{{ section.id }} {
      min-height: {{ section.settings.min_height }}vh;
    }
  }
  .ch-hero-{{ section.id }} .ch-hero__overlay {
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }
{%- endstyle -%}

<section class="ch-hero ch-hero-{{ section.id }}" aria-label="{{ section.settings.heading | escape }}">
  {%- if section.settings.image != blank -%}
    <div class="ch-hero__media">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 1780, 2000',
          sizes: '100vw',
          class: 'ch-hero__img'
      }}
    </div>
  {%- elsif section.settings.mobile_image != blank -%}
    <div class="ch-hero__media">
      {{
        section.settings.mobile_image
        | image_url: width: 800
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'ch-hero__img'
      }}
    </div>
  {%- else -%}
    <div class="ch-hero__media ch-hero__media--placeholder"></div>
  {%- endif -%}

  <div class="ch-hero__overlay"></div>

  <div class="ch-hero__content ch-hero__content--{{ section.settings.content_position }}">
    <div class="ch-hero__inner">
      {%- if section.settings.subheading != blank -%}
        <p class="ch-hero__eyebrow">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="ch-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="ch-hero__desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
      <div class="ch-hero__cta-group">
        {%- if section.settings.btn1_label != blank -%}
          <a
            href="{{ section.settings.btn1_link | default: '/collections/all' }}"
            class="ch-hero__btn ch-hero__btn--primary"
          >
            {{ section.settings.btn1_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a
            href="{{ section.settings.btn2_link | default: '/pages/about-us' }}"
            class="ch-hero__btn ch-hero__btn--secondary"
          >
            {{ section.settings.btn2_label | escape }}
          </a>
        {%- endif -%}
      </div>
      {%- if section.settings.show_trust_strip -%}
        <div class="ch-hero__trust-strip">
          <span>✓ FSSAI Approved</span>
          <span>✓ Lab Tested</span>
          <span>✓ No Fillers</span>
          <span>✓ Free Shipping ₹499+</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Hero Banner",
  "tag": "section",
  "class": "ch-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image (recommended: 2000×900px)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (optional, recommended: 800×1000px)"
    },
    {
      "type": "color",
      "id": "fallback_bg_color",
      "label": "Fallback Background Color",
      "default": "#1B4332"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop Min Height",
      "default": 85
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile Min Height",
      "default": 70
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow / Subheading",
      "default": "Welcome to CueHealth"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Main Heading",
      "default": "<p>Your Cue to <em>Healthy Life</em></p>"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Science-backed supplements crafted for real, lasting wellness. FSSAI approved. Lab tested. No fillers."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Secondary Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Trust Strip"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show Trust Strip Below Buttons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner",
      "settings": {
        "subheading": "Welcome to CueHealth",
        "heading": "<p>Your Cue to <em>Healthy Life</em></p>",
        "description": "Science-backed supplements crafted for real, lasting wellness.",
        "btn1_label": "Shop Now",
        "btn2_label": "Our Story",
        "overlay_opacity": 40,
        "min_height": 85,
        "min_height_mobile": 70,
        "content_position": "left",
        "show_trust_strip": true
      }
    }
  ]
}
{% endschema %}
